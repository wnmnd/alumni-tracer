# --- Server ---
PORT=3000

# --- WhatsApp Cloud API (Meta) ---
# Use a permanent System User token for production - the "temporary" token from
# WhatsApp Manager's test number expires after ~24 hours.
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
GRAPH_API_VERSION=v23.0

# Any string you choose. Enter the same value in Meta App Dashboard > WhatsApp > Configuration > Webhook.
WEBHOOK_VERIFY_TOKEN=

# Meta App Secret, used to verify X-Hub-Signature-256 on incoming webhooks. Recommended, optional for local testing.
META_APP_SECRET=

# Message text (case-insensitive) that triggers sending the alumni Flow form.
FLOW_TRIGGER_KEYWORD=tracer alumni

# --- WhatsApp Flow ---
# Filled in after running `npm run create-flow` (see README).
FLOW_ID=
# PEM contents of the RSA private key generated by `npm run generate-keys`.
# Paste the whole PEM (including BEGIN/END lines) - use \n for newlines if set as a single-line env var on Render.
FLOW_PRIVATE_KEY=
# Only needed if you generated the key pair with a passphrase.
FLOW_PRIVATE_KEY_PASSPHRASE=

# --- Google Sheet (via Apps Script Web App, see apps-script/Code.gs and README) ---
# The deployed Web App URL, ends in /exec.
APPS_SCRIPT_URL=
# Must match the SECRET constant set in the Apps Script.
APPS_SCRIPT_SECRET=

# --- Telegram bot ---
# From @BotFather
TELEGRAM_BOT_TOKEN=
# Public HTTPS URL of this deployed server (used to build the Mini App form link), e.g. https://your-app.onrender.com
PUBLIC_BASE_URL=
